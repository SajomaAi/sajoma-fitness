# RE Assistant — Environment Configuration
# Copy this file to .env and fill in your values

# ── CRM ──
CRM_PROVIDER=followupboss        # followupboss | kvcore | hubspot
CRM_API_KEY=
CRM_BASE_URL=

# ── Email (SendGrid / Mailgun) ──
EMAIL_PROVIDER=sendgrid          # sendgrid | mailgun
EMAIL_API_KEY=
EMAIL_FROM=agent@example.com
EMAIL_FROM_NAME=Your Name

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Facebook ──
FB_PAGE_ID=
FB_ACCESS_TOKEN=

# ── Instagram ──
IG_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# ── TikTok ──
TIKTOK_OPEN_ID=
TIKTOK_ACCESS_TOKEN=

# ── MLS (RETS / RESO) ──
MLS_PROVIDER=reso                # rets | reso
MLS_LOGIN_URL=
MLS_USERNAME=
MLS_PASSWORD=

# ── DocuSign ──
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=

# ── Google Calendar ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Google Ads ──
GOOGLE_ADS_DEV_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── Meta Ads ──
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# ── Redis (for job queue) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Database ──
DATABASE_URL=postgresql://user:password@localhost:5432/re_assistant
